  "config_files": {
    "app.json": {
      "expo": {
        "name": "Paint Match Notebook",
        "slug": "paint-match-notebook",
        "version": "1.0.0",
        "orientation": "portrait",
        "icon": "./assets/images/icon.png",
        "scheme": "rork-app",
        "userInterfaceStyle": "automatic",
        "newArchEnabled": true,
        "splash": {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        },
        "ios": {
          "supportsTablet": false,
          "bundleIdentifier": "app.tminus.paint-match-notebook",
          "infoPlist": {
            "NSPhotoLibraryUsageDescription": "Allow $(PRODUCT_NAME) to access your photos",
            "NSCameraUsageDescription": "Allow $(PRODUCT_NAME) to access your camera",
            "NSMicrophoneUsageDescription": "Allow $(PRODUCT_NAME) to access your microphone",
            "ITSAppUsesNonExemptEncryption": false
          }
        },
        "android": {
          "adaptiveIcon": {
            "foregroundImage": "./assets/images/adaptive-icon.png",
            "backgroundColor": "#ffffff"
          },
          "package": "app.rork.paint_match_notebook",
          "permissions": [
            "android.permission.CAMERA",
            "android.permission.READ_EXTERNAL_STORAGE",
            "android.permission.WRITE_EXTERNAL_STORAGE",
            "android.permission.VIBRATE",
            "android.permission.INTERNET",
            "android.permission.RECORD_AUDIO"
          ]
        },
        "web": {
          "favicon": "./assets/images/favicon.png"
        },
        "plugins": [
          [
            "expo-router",
            {
              "origin": "https://rork.com/"
            }
          ],
          "expo-font",
          "expo-web-browser",
          [
            "expo-image-picker",
            {
              "photosPermission": "The app accesses your photos to let you share them with your friends."
            }
          ]
        ],
        "experiments": {
          "typedRoutes": true
        },
        "owner": "robert_castagna",
        "extra": {
          "router": {
            "origin": "https://rork.com/"
          },
          "eas": {
            "projectId": "9821ddb4-cca5-45b0-a3a1-38b73e0b6fc8"
          }
        }
      }
    },
    "package.json": {
      "name": "expo-app",
      "main": "expo-router/entry",
      "version": "1.0.0",
      "scripts": {
        "start": "bunx rork start -p h9usctyldi1x0mp3sanq5 --tunnel",
        "start-web": "bunx rork start -p h9usctyldi1x0mp3sanq5 --web --tunnel",
        "start-web-dev": "DEBUG=expo* bunx rork start -p h9usctyldi1x0mp3sanq5 --web --tunnel",
        "lint": "expo lint",
        "android": "expo run:android",
        "ios": "expo run:ios"
      },
      "dependencies": {
        "@expo/vector-icons": "^15.0.3",
        "@nkzw/create-context-hook": "^1.1.0",
        "@react-native-async-storage/async-storage": "2.2.0",
        "@rork-ai/toolkit-sdk": "0.2.54",
        "@stardazed/streams-text-encoding": "^1.0.2",
        "@tanstack/react-query": "^5.83.0",
        "@ungap/structured-clone": "^1.3.0",
        "expo": "~54.0.27",
        "expo-blur": "~15.0.8",
        "expo-constants": "~18.0.11",
        "expo-file-system": "~19.0.21",
        "expo-font": "~14.0.10",
        "expo-haptics": "~15.0.8",
        "expo-image": "~3.0.11",
        "expo-image-picker": "~17.0.9",
        "expo-linear-gradient": "~15.0.8",
        "expo-linking": "~8.0.10",
        "expo-location": "~19.0.8",
        "expo-router": "~6.0.17",
        "expo-splash-screen": "~31.0.12",
        "expo-status-bar": "~3.0.9",
        "expo-symbols": "~1.0.8",
        "expo-system-ui": "~6.0.9",
        "expo-web-browser": "~15.0.10",
        "lucide-react-native": "0.577.0",
        "react": "19.1.0",
        "react-dom": "19.1.0",
        "react-native": "0.81.5",
        "react-native-gesture-handler": "~2.28.0",
        "react-native-safe-area-context": "~5.6.0",
        "react-native-screens": "~4.16.0",
        "react-native-svg": "15.12.1",
        "react-native-web": "^0.21.0",
        "react-native-worklets": "0.5.1",
        "zod": "^4.3.5",
        "zustand": "^5.0.2"
      },
      "devDependencies": {
        "@babel/core": "^7.25.2",
        "@expo/ngrok": "^4.1.0",
        "@types/react": "~19.1.10",
        "eslint": "^9.31.0",
        "eslint-config-expo": "~10.0.0",
        "typescript": "~5.9.2"
      },
      "private": true,
      "overrides": {
        "expo-location": "~19.0.8"
      }
    },
    "eas.json": {
      "cli": {
        "version": ">= 11.0.0",
        "appVersionSource": "remote"
      },
      "build": {
        "production": {
          "autoIncrement": true,
          "credentialsSource": "local"
        }
      }
    }
  },
